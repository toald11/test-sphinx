\usepackage{enumitem}
\setlist[description]{style=nextline}

% ==================================
% インラインリテラル
% ==================================

\usepackage{tcolorbox}
\makeatletter
% 元の定義を退避
\let\orig@sphinxupquote\sphinxupquote
% 元の定義を上書き
\renewcommand{\sphinxupquote}[1]{
  \if\relax\detokenize{#1}\relax
    % 内容が空文字である場合、ボックスは使用しない
    \orig@sphinxupquote{#1}
  \else
    \tcbox[
        on line,
        colframe=gray,
        colback=white,
        size=fbox,
        top=0pt,
        bottom=0pt,
        boxsep=1.2pt
    ]{%
        \orig@sphinxupquote{#1}
    }%
  \fi
}
\makeatother

